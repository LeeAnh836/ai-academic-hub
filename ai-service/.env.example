# AI Service Environment Variables

# Service Configuration
SERVICE_NAME=JVB AI Service
SERVICE_VERSION=1.0.0
HOST=0.0.0.0
PORT=8001
DEBUG=True

# Qdrant Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=jvb_embeddings
QDRANT_API_KEY=

# Neo4j Configuration (GraphRAG - Cloud)
# Get credentials from: https://console.neo4j.io
ENABLE_NEO4J=false
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# Cohere Configuration
COHERE_API_KEY=your_cohere_api_key_here
COHERE_EMBEDDING_MODEL=embed-multilingual-v3.0
COHERE_LLM_MODEL=command-r-plus
VECTOR_DIMENSION=1024

# RAG Configuration
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7
RAG_MAX_CONTEXT_LENGTH=8000

# GraphRAG Configuration
ENABLE_GRAPH_RAG=false
GRAPH_RAG_MODE=hybrid  # Options: vector_only, graph_only, hybrid
GRAPH_EXTRACTION_MODEL=gemini  # Use Gemini Flash for FREE entity extraction
GRAPH_MAX_ENTITIES=50  # Max entities per chunk
GRAPH_TOP_K=10  # Top K entities from graph
GRAPH_TRAVERSAL_DEPTH=2  # Relationship traversal depth

# Advanced RAG Configuration
ENABLE_ADVANCED_RAG=True           # Full Advanced RAG pipeline (query expansion + reranking + CRAG)
ENABLE_QUERY_REWRITING=True        # Multi-query expansion (generates N variants)
QUERY_REWRITE_VARIANTS=3           # Number of query variants to generate
ENABLE_BM25_RESCORING=True         # BM25 hybrid keyword rescoring on retrieved chunks
BM25_VECTOR_WEIGHT=0.7             # Vector weight in hybrid score (1-this = BM25 weight)
ENABLE_RERANKING=True              # Cross-encoder re-ranking after retrieval
ENABLE_COHERE_RERANK=True          # Use Cohere Rerank API (multilingual, same COHERE_API_KEY)
COHERE_RERANK_MODEL=rerank-multilingual-v3.0
ADVANCED_RAG_INITIAL_TOP_K=15      # Retrieve this many chunks before re-ranking
ADVANCED_RAG_FINAL_TOP_K=5         # Keep this many after re-ranking
ENABLE_CORRECTIVE_RAG=True         # CRAG: evaluate quality and re-retrieve if insufficient
CRAG_MAX_ATTEMPTS=2                # Max corrective re-retrieval attempts
ENABLE_MULTI_HOP=True              # Multi-hop reasoning for complex comparison queries

# LLM Configuration
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60

# Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Redis Configuration (Memory Management)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
MEMORY_TTL=3600

# Multi-Agent Settings
ENABLE_MULTI_AGENT=True
ENABLE_PROMPT_PREPROCESSING=True
ENABLE_DATA_ANALYSIS=True
ENABLE_CODE_EXECUTION=True

# Code Execution Settings
CODE_EXEC_TIMEOUT=30
CODE_EXEC_DOCKER_IMAGE=python:3.11-slim
CODE_EXEC_MAX_OUTPUT_SIZE=10000

# Data Analysis Settings
PANDAS_MAX_ROWS=10000
PANDAS_MAX_COLUMNS=100
ENABLE_CHART_GENERATION=True

# MCP Settings (Future)
ENABLE_MCP=False
MCP_SERVER_URL=

# Gemini & Groq Settings
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_FLASH_MODEL=gemini-1.5-flash-latest
GEMINI_PRO_MODEL=gemini-1.5-pro-latest
GROQ_API_KEY=your_groq_api_key_here
GROQ_LLAMA_MODEL=llama-3.3-70b-versatile

# CORS
CORS_ORIGINS=*

